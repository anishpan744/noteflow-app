rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // OG link preview cache — internal only. Served exclusively through the
    // scrapeOpenGraph callable (Admin SDK bypasses rules). Clients must not be
    // able to read/list it, since docs hold raw URLs other users have pasted.
    match /ogCache/{docId} {
      allow read, write: if false;
    }

    // All user data — strictly scoped to the owning user
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
